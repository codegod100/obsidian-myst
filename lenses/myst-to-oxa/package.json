{
  "name": "@nandithebull/myst-to-oxa",
  "version": "0.1.0",
  "description": "TypeScript SDK for converting MyST documents to OXA tree-model format",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "myst",
    "oxa",
    "panproto",
    "converter",
    "atproto"
  ]
}
